# MedDiagnose Backend - Environment Template
# Copy to .env and fill in values. Never commit .env with real secrets.

# ── App ──
APP_NAME=MedDiagnose
DEBUG=true
# Production: LOG_FORMAT=json, LOG_LEVEL=INFO, USE_REDIS_FOR_LIMITER=true
# LOG_FORMAT=json ships to CloudWatch/Datadog/ELK via stdout

# ── Database ──
DATABASE_URL=postgresql+asyncpg://meddiagnose:meddiagnose@localhost:5432/meddiagnose
DATABASE_URL_SYNC=postgresql+psycopg2://meddiagnose:meddiagnose@localhost:5432/meddiagnose

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Security ──
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage ──
UPLOAD_DIR=./uploads

# ── Airflow (batch DAG when Kafka disabled) ──
AIRFLOW_API_URL=http://localhost:8080/api/v1
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# ── Kafka (parallel bulk diagnosis) ──
# Set KAFKA_ENABLED=true to use Kafka instead of Airflow for batch uploads
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_DIAGNOSIS_TOPIC=meddiagnose-diagnosis-jobs
# Use GCP Vertex AI instead of Ollama for Kafka consumer inference
KAFKA_USE_VERTEX_AI=false

# ── GCP Vertex AI (required when KAFKA_USE_VERTEX_AI=true) ──
# GCP_PROJECT_ID=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1
# MEDGEMMA_ENDPOINT_4B=your-vertex-ai-endpoint-id
# MEDGEMMA_ENDPOINT_27B=optional-27b-endpoint

# ── Ollama (single diagnosis + Kafka when KAFKA_USE_VERTEX_AI=false) ──
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=alibayram/medgemma:4b
# Vision model for image-based diagnosis (X-rays, lab reports, skin photos)
# OLLAMA_MULTIMODAL_MODEL=dcarrascosa/medgemma-1.5-4b-it
# 27B model for higher accuracy (requires more GPU/RAM)
# OLLAMA_MODEL_27B=alibayram/medgemma:27b

# ── Inference Worker (Celery GPU tasks) ──
# INFERENCE_WORKER_URL=http://localhost:8001

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:5173"]

# ── Insurance (Star Health, HDFC Ergo, Max Bupa, Axis, Government) ──
# Real connection: Register at https://sbxhcx.abdm.gov.in, get credentials
# ABDM_CLIENT_ID=your-participant-id
# ABDM_CLIENT_SECRET=your-secret
# ABDM_BASE_URL=https://sbxhcx.abdm.gov.in
# ABDM_AUTH_URL=  # Override if auth at different URL
# NHCX_CALLBACK_URL=https://yourdomain.com/api/v1/insurance/hcx/callback
# Private insurers: set when partner API access is available
# STAR_HEALTH_API_URL=
# STAR_HEALTH_API_KEY=
# HDFC_ERGO_API_URL=
# HDFC_ERGO_API_KEY=
# MAX_BUPA_API_URL=
# MAX_BUPA_API_KEY=
# AXIS_HEALTH_API_URL=
# AXIS_HEALTH_API_KEY=
# LIC_API_URL=   # LIC Jeevan Arogya - when partner API available
# LIC_API_KEY=

# ── Region (for medication availability) ──
# REGION=India  # Prescribe drugs available in Indian pharmacies (default)

# ── SSO (Google OAuth2) ──
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: http://localhost:8001/api/v1/auth/google/callback
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback
# FRONTEND_URL=http://localhost:5173

# ── Keycloak OIDC ──
# Create a client in Keycloak Admin Console. Add redirect URI: http://localhost:8001/api/v1/auth/keycloak/callback
# KEYCLOAK_URL=https://your-keycloak.example.com
# KEYCLOAK_REALM=meddiagnose
# KEYCLOAK_CLIENT_ID=meddiagnose-web
# KEYCLOAK_CLIENT_SECRET=your-client-secret
# KEYCLOAK_REDIRECT_URI=http://localhost:8001/api/v1/auth/keycloak/callback
